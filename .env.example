# Zerodha login credentials
ZERODHA_USER_ID=AB1234
ZERODHA_PASSWORD=your_password_here

# Optional: base32 TOTP setup key for fully automated login (no prompt).
# Get it from: kite.zerodha.com → My Profile → Account Security → 2FA → "Use setup key"
# If left blank, main.py will prompt you to type the 6-digit code from your app each morning.
ZERODHA_TOTP_SECRET=
